# vLLM configuration
# Change VLLM_MODEL to swap the served model; restart vllm container to apply.
# VLLM_SERVED_NAME is the short alias exposed in the API (use this name in HA and OpenWebUI).

VLLM_VERSION=26.03-py3
VLLM_MODEL=nvidia/Llama-3.1-8B-Instruct-FP8
VLLM_SERVED_NAME=llama-3.1-8b
TENSOR_PARALLEL_SIZE=1
MAX_MODEL_LEN=32768
GPU_MEM_UTIL=0.85

# HuggingFace token — required for gated models (e.g., Llama, Gemma)
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=
